# =============================================================================
# Deployment environment — copy to .env and fill in real values
# The 'db' hostname resolves to the MySQL container inside docker-compose.
# =============================================================================

# =============================================================================
# MySQL container
# =============================================================================
MYSQL_ROOT_PASSWORD=changeme_root
MYSQL_DATABASE=vmcontrol

# =============================================================================
# Database (app connects to the 'db' container)
# =============================================================================
DB_URL=jdbc:mysql://db:3306/vmcontrol?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
DB_DRIVER=com.mysql.cj.jdbc.Driver
DB_USERNAME=vmcontrol
DB_PASSWORD=changeme_app
DB_PLATFORM=org.hibernate.dialect.MySQLDialect
JPA_DDL_AUTO=validate
H2_CONSOLE_ENABLED=false

# =============================================================================
# Flyway
# =============================================================================
FLYWAY_CLEAN_ON_VALIDATION_ERROR=false
FLYWAY_BASELINE_ON_MIGRATE=true
FLYWAY_OUT_OF_ORDER=false

# =============================================================================
# Entra ID (Azure AD) OAuth2
# =============================================================================
ENTRAID_ENABLED=true
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret
AZURE_TENANT_ID=your-tenant-id

# =============================================================================
# AWS
# =============================================================================
AWS_ACCESS_KEY=your-aws-access-key
AWS_SECRET_KEY=your-aws-secret-key
AWS_REGION=ap-south-1

# =============================================================================
# VM State Sync
# =============================================================================
VM_STATE_SYNC_ENABLED=true
VM_STATE_SYNC_INTERVAL=300000
VM_STATE_SYNC_INITIAL_DELAY=60000

# =============================================================================
# Application
# =============================================================================
APP_INITIAL_ADMIN_EMAIL=admin@example.com
APP_PORT=8080
