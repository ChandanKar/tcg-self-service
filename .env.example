# =============================================================================
# .env.example - Copy this file to .env and update values
# =============================================================================

# =============================================================================
# Database Configuration (H2 for development)
# =============================================================================
DB_URL=jdbc:h2:file:./data/vmcontrol;DB_CLOSE_DELAY=-1;DB_CLOSE_ON_EXIT=FALSE;MODE=MySQL;NON_KEYWORDS=VALUE
DB_DRIVER=org.h2.Driver
DB_USERNAME=sa
DB_PASSWORD=
DB_PLATFORM=org.hibernate.dialect.H2Dialect
JPA_DDL_AUTO=update
H2_CONSOLE_ENABLED=true
H2_CONSOLE_PATH=/h2-console

# =============================================================================
# Flyway Configuration
# =============================================================================
FLYWAY_CLEAN_ON_VALIDATION_ERROR=false
FLYWAY_BASELINE_ON_MIGRATE=true
FLYWAY_OUT_OF_ORDER=false

# =============================================================================
# Entra ID (Azure AD) OAuth2 Authentication
# =============================================================================
ENTRAID_ENABLED=true
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret
AZURE_TENANT_ID=your-tenant-id

# =============================================================================
# AWS Configuration
# =============================================================================
AWS_ACCESS_KEY=your-aws-access-key
AWS_SECRET_KEY=your-aws-secret-key
AWS_REGION=ap-south-1

# =============================================================================
# VM State Sync Configuration
# =============================================================================
VM_STATE_SYNC_ENABLED=true
VM_STATE_SYNC_INTERVAL=300000
VM_STATE_SYNC_INITIAL_DELAY=60000

# =============================================================================
# EKS Sync Configuration
# =============================================================================
EKS_SYNC_ENABLED=true
EKS_SYNC_INTERVAL=300000
EKS_SYNC_INITIAL_DELAY=60000

# =============================================================================
# User Management Configuration
# =============================================================================
APP_INITIAL_ADMIN_EMAIL=admin@example.com

